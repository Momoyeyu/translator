# ===========================================
# Translator Agent - Environment Variables
# ===========================================
# Copy this file to .env and update the values
# for your environment.

# ===========================================
# Database Configuration
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=translator

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ===========================================
# Security Configuration
# IMPORTANT: Change these in production!
# ===========================================
JWT_SECRET=change-me-to-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=3600
REFRESH_TOKEN_EXPIRE_SECONDS=604800
VERIFICATION_CODE_EXPIRE_SECONDS=300

# ===========================================
# Email (Resend)
# ===========================================
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# ===========================================
# Invitation Code
# ===========================================
REQUIRE_INVITATION_CODE=false

# ===========================================
# Tenant Invitation
# ===========================================
INVITATION_TOKEN_EXPIRE_SECONDS=604800
FRONTEND_URL=http://localhost:3000

# ===========================================
# LLM Configuration (OpenAI-compatible)
# ===========================================
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===========================================
# Application Settings
# ===========================================
APP_NAME=Translator
DEBUG=false

# ===========================================
# Server Configuration
# ===========================================
SERVER_HOST=localhost
SERVER_PORT=8000

# ===========================================
# Docker Image (used by CD pipeline)
# ===========================================
DOCKER_IMAGE=translator-backend:latest

# ===========================================
# Kafka Configuration
# ===========================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=translator-workers

# ===========================================
# Storage Configuration
# ===========================================
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_S3_BUCKET=
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_REGION=

# ===========================================
# LLM Profiles
# ===========================================
LLM_FAST_MODEL_NAME=
LLM_PRO_MODEL_NAME=

# ===========================================
# ACPs Configuration
# ===========================================
ACPS_ENABLED=false
ACPS_AIC=1.2.156.3088.0001.00001.000001.0.1.0000
ACPS_CERT_DIR=./certs
ACPS_MOCK_AUTH=true

# ===========================================
# Pipeline Configuration
# ===========================================
MAX_CONCURRENT_PROJECTS_PER_USER=3
MAX_UPLOAD_SIZE_MB=50
